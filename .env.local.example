# Copy to .env.local and fill in. Never commit .env.local.

# Supabase project — Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — Settings → API. SERVER-SIDE ONLY. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Google Cloud — Places API (New) enabled, key restricted to that API.
GOOGLE_PLACES_API_KEY=

# Shared secret gating the Google Sheet sync routes (/api/admin/import|export).
# Use any long random string; set the SAME value in the sheet's Apps Script
# (SYNC_SECRET) and in your host's env vars. Generate one: openssl rand -hex 24
IMPORT_SECRET=

# Email notifications for form submissions (optional). Sign up at resend.com.
RESEND_API_KEY=
NOTIFY_EMAIL=          # where suggestion/claim alerts are sent
# NOTIFY_FROM=Sea Isle Eats <notifications@siceats.com>  # optional; needs a verified domain in Resend
